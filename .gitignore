# Dependencies
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime logs — contain sensitive failed record data
logs/

# Environment Variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build output
dist/
build/
out/

# Prisma
# Ignore auto-generated SQLite DB if testing locally (optional)
prisma/*.db
prisma/*.db-journal

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs and Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# AWS DocumentDB TLS Certificate
# This is a PUBLIC certificate but should NOT be committed —
# it's large (165KB), AWS rotates it, and devs should always get the latest.
# Download at setup time: curl -o global-bundle.pem https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
global-bundle.pem
*.pem

# MongoDB backup snapshots
backups/
backup/

